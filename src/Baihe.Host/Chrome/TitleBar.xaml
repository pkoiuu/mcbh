<!--
    macOS 风格交通灯标题栏 — 三色按钮 + 居中标题
    高度 44px，背景半透明
-->
<UserControl x:Class="Baihe.Host.Chrome.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="44"
             Background="#CC1A1A1A"
             MouseDown="OnTitleBarMouseDown">
    <Grid>
        <!-- 居中标题文字 — 覆盖整个宽度 -->
        <TextBlock Text="白鹤服务器"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="13"
                   IsHitTestVisible="False" />

        <!-- macOS 交通灯按钮 — 左对齐 -->
        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Margin="12,0,0,0">
            <!-- 关闭按钮 #FF5F57 -->
            <Ellipse Width="12" Height="12"
                     Fill="#FF5F57"
                     Margin="0,0,8,0"
                     MouseDown="OnCloseMouseDown" />
            <!-- 最小化按钮 #FEBC2E -->
            <Ellipse Width="12" Height="12"
                     Fill="#FEBC2E"
                     Margin="0,0,8,0"
                     MouseDown="OnMinimizeMouseDown" />
            <!-- 最大化按钮 #28C840 -->
            <Ellipse Width="12" Height="12"
                     Fill="#28C840"
                     MouseDown="OnMaximizeMouseDown" />
        </StackPanel>
    </Grid>
</UserControl>
