<!--
    主窗口 — 承载 WebView2 加载前端
    自定义无边框窗口，使用 macOS 风格交通灯标题栏
-->
<Window x:Class="Baihe.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:chrome="clr-namespace:Baihe.Host.Chrome"
        Title="白鹤服务器"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <!-- WindowChrome 用于自定义窗口边框 — 移除默认标题栏和玻璃效果 -->
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CaptionHeight="0"
                      ResizeBorderThickness="6"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <!-- 主布局：标题栏（44px）+ WebView2（填充剩余） -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- macOS 风格交通灯标题栏 -->
        <chrome:TitleBar Grid.Row="0" x:Name="TitleBar" />

        <!-- WebView2 宿主控件 -->
        <wv2:WebView2 Grid.Row="1" x:Name="WebView" />
    </Grid>
</Window>
