# 使用 hoisted 模式，避免 Windows 上的符号链接 EBUSY 问题
node-linker=hoisted
# 禁止 corepack 自动管理 pnpm 版本
manage-package-manager-versions=false
# 跳过运行脚本前的依赖检查，避免 registerProject 触发 EBUSY 错误
verify-deps-before-run=false
# 注意: 在 Windows 上，pnpm v11 的 registerProject 功能会创建指向项目目录的符号链接。
# 如果 pnpm 的 cwd 是项目目录，该目录会被锁定，导致 EBUSY 错误。
# 解决方案: 从项目目录之外运行 pnpm，用 --dir 参数指定项目目录。
# 示例: pnpm --dir d:\github-git\mcbh\src\Baihe.UI install
